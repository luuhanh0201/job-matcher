{
  "dependencies": {
    "@nestjs/mapped-types": "*"
  },
  "name": "job-matcher",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "pnpm -r --if-present run lint:fix",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "prettier": "^3.7.4",
    "turbo": "^2.9.6",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}